{
  "expo": {
    "name": "rota-facil",
    "slug": "rota-facil",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rotafacil",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.rotafacil.app",
      "adaptiveIcon": {
        "backgroundColor": "#076AFD",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.CAMERA", "android.permission.RECORD_AUDIO"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#076AFD",
          "dark": {
            "backgroundColor": "#076AFD"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "O Rota Fácil usa sua localização para acompanhar seu deslocamento durante o transporte escolar.",
          "locationAlwaysAndWhenInUsePermission": "O Rota Fácil usa sua localização em segundo plano para manter o acompanhamento do transporte escolar.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permita que o Rota Fácil use a câmera para ler QR Codes de viagens."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "45ff1ba1-d9ff-40df-b5e5-1c2db2bc2151"
      }
    },
    "owner": "dom-gean"
  }
}
